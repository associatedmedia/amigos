{
  "expo": {
    "name": "Amigos Driver",
    "slug": "AmigosDriver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "amigosdriver",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyA024waSwg_D8uc9p631ClPteTdpDRDQ4U"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to track delivery progress and show routes to customers.",
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA024waSwg_D8uc9p631ClPteTdpDRDQ4U"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "android.permission.INTERNET"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.associatedmedia.amigospizzadrivers"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8367ab9f-346a-4604-88b1-65244c5affc2"
      }
    }
  }
}